# API 配置
API_BASE_URL=http://localhost:8000
API_KEY=your_api_key_here

# LLM 配置
LLM_PROVIDER=openai
LLM_MODEL=gpt-4
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=4096

# RAG 配置
VECTOR_DB_PATH=./data/vector_db
EMBEDDING_MODEL=text-embedding-3-small
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# 数据库
DATABASE_URL=sqlite:///./data/app.db

# 日志
LOG_LEVEL=INFO
